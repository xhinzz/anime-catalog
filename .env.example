# ===== REQUIRED =====

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Supabase - Get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
DATABASE_URL=postgresql://postgres.XXXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.XXXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== OPTIONAL =====

# Discord OAuth - https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Resend (email verification) - https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=AnimeList <onboarding@resend.dev>
